{
	"name": "@opral/flashtype",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
		"dev:renderer": "vite --host 127.0.0.1 --port 4173 --strictPort",
		"dev:electron": "wait-on tcp:4173 && VITE_DEV_SERVER_URL=http://127.0.0.1:4173 electron ./electron/main.mjs",
		"rebuild:electron-native": "electron-rebuild -f -w better-sqlite3,node-pty",
		"dev:web": "vite",
		"predev": "pnpm run build:lix && pnpm run rebuild:electron-native",
		"build": "vite build",
		"prebuild": "pnpm run build:lix",
		"postinstall": "command -v cargo >/dev/null 2>&1 && cargo fetch --manifest-path submodule/lix/Cargo.toml || true",
		"build:lix": "pnpm -C submodule/lix exec nx run-many --nx-bail --target=build --projects=@lix-js/react-utils,@lix-js/sdk && pnpm -C submodule/lix --filter @lix-js/better-sqlite3-backend run build && cargo build --manifest-path submodule/lix/packages/plugin-md-v2/Cargo.toml --target wasm32-wasip2 --release",
		"preview": "vite preview --strictPort --port 5173",
		"typecheck": "tsc -p . --pretty false",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --format stylish .",
		"lint:fix": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --fix .",
		"test": "vitest run",
		"ci": "pnpm run build && pnpm test"
	},
	"dependencies": {
		"@base-ui-components/react": "1.0.0-beta.4",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"@lix-js/better-sqlite3-backend": "workspace:*",
		"@lix-js/kysely": "workspace:*",
		"@lix-js/react-utils": "workspace:*",
		"@lix-js/sdk": "workspace:*",
		"@opral/markdown-wc": "0.6.0",
		"@radix-ui/react-avatar": "^1.1.10",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.11",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tiptap/core": "^3.3.0",
		"@tiptap/extension-history": "^3.4.4",
		"@tiptap/extension-placeholder": "^3.4.4",
		"@tiptap/pm": "^3.3.0",
		"@tiptap/react": "^3.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"kysely": "^0.28.7",
		"lucide-react": "^0.542.0",
		"node-pty": "^1.0.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-resizable-panels": "^2.1.9",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.3",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.0",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitejs/plugin-react": "^5.0.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"electron": "^40.6.1",
		"happy-dom": "^18.0.1",
		"oxlint": "^1.23.0",
		"prettier": "^3.6.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.7",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"vitest": "^4.0.3",
		"wait-on": "^9.0.4"
	}
}
