{
	"name": "@opral/flashtype",
	"private": true,
	"version": "0.7.3",
	"type": "module",
	"main": "electron/main.mjs",
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"dev:renderer": "vite --host 127.0.0.1 --port 4173 --strictPort",
		"dev:electron": "wait-on tcp:4173 && VITE_DEV_SERVER_URL=http://127.0.0.1:4173 electron ./electron/main.mjs",
		"build:icons": "cargo flashtype-icons",
		"build:env-variables": "node scripts/write-env-variables.mjs",
		"build:posthog-sourcemaps": "node scripts/upload-posthog-sourcemaps.mjs",
		"rebuild:electron-native": "electron-rebuild -f -w node-pty",
		"package:mac": "pnpm run build:icons && pnpm run build && pnpm run build:env-variables && pnpm run rebuild:electron-native && electron-builder --mac --publish never",
		"install:mac": "pnpm run package:mac && node scripts/install-mac.mjs",
		"release:mac": "pnpm run build:icons && pnpm run build && pnpm run build:posthog-sourcemaps && pnpm run build:env-variables && pnpm run rebuild:electron-native && electron-builder --mac --publish always",
		"dev:web": "vite",
		"predev": "pnpm run build:atelier && pnpm run rebuild:electron-native",
		"build": "vite build",
		"prebuild": "pnpm run build:atelier",
		"build:atelier": "pnpm --filter @opral/atelier build",
		"preview": "vite preview --strictPort --port 5173",
		"typecheck": "tsc -p . --pretty false",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --ignore-pattern \"submodule/**\" --format stylish .",
		"lint:fix": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --ignore-pattern \"submodule/**\" --fix .",
		"test": "vitest run",
		"pretest:e2e": "pnpm run rebuild:electron-native",
		"test:e2e": "FLASHTYPE_HEADLESS=1 playwright test",
		"pretest:e2e:headed": "pnpm run pretest:e2e",
		"test:e2e:headed": "FLASHTYPE_HEADLESS=0 playwright test",
		"test:e2e:packaged-macos": "playwright test --config playwright.packaged.config.ts",
		"ci": "pnpm run build && pnpm test"
	},
	"dependencies": {
		"@opral/atelier": "workspace:*",
		"@base-ui-components/react": "1.0.0-beta.4",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@glideapps/glide-data-grid": "^6.0.3",
		"@lix-js/html-diff": "^0.1.0",
		"@lix-js/sdk": "0.8.2",
		"@pierre/trees": "1.0.0-beta.4",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tiptap/core": "^3.27.3",
		"@tiptap/extension-history": "^3.27.3",
		"@tiptap/extension-placeholder": "^3.27.3",
		"@tiptap/pm": "^3.27.3",
		"@tiptap/react": "^3.27.3",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-updater": "^6.8.9",
		"kysely": "^0.28.7",
		"lodash": "^4.18.1",
		"lucide-react": "^0.542.0",
		"marked": "^4.3.0",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-frontmatter": "^2.0.1",
		"mdast-util-gfm": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mermaid": "^11.16.0",
		"micromark-extension-frontmatter": "^2.0.0",
		"micromark-extension-gfm": "^3.0.0",
		"node-pty": "^1.0.0",
		"papaparse": "^5.5.3",
		"posthog-js": "^1.393.0",
		"posthog-node": "^5.38.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-resizable-panels": "^2.1.9",
		"react-responsive-carousel": "^3.2.23",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@electron/notarize": "^3.1.1",
		"@electron/rebuild": "^4.0.3",
		"@playwright/test": "^1.60.0",
		"@posthog/cli": "^0.7.30",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.0",
		"@types/node": "^24.10.2",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/seedrandom": "^3.0.8",
		"@vitejs/plugin-react": "^5.0.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"electron": "^40.6.1",
		"electron-builder": "^26.15.2",
		"happy-dom": "^18.0.1",
		"oxlint": "^1.23.0",
		"playwright": "^1.60.0",
		"prettier": "^3.6.2",
		"seedrandom": "^3.0.5",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.7",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"vitest": "^4.0.3",
		"wait-on": "^9.0.4"
	}
}
