{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"types": ["vite/client"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
